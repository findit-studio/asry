**.idea/

# Generated by Cargo
# will have compiled files and executables
**target/

# Remove Cargo.lock from gitignore if creating an executable, leave it for libraries
# More information here https://doc.rust-lang.org/cargo/guide/cargo-toml-vs-cargo-lock.html
**Cargo.lock

# These are backup files generated by rustfmt
**/*.rs.bk


# Added by cargo

/target
Cargo.lock

.claude/

target/whispery-test-fixtures/
docs/
models/

# Audio parity fixtures live in https://github.com/Findit-AI/audio-fixtures.
# CI (or `scripts/fetch_fixtures.sh` for local runs) populates
# tests/parity/fixtures/ at test time. The directory MUST stay
# untracked here so the ~283 MB of WAV blobs never end up in
# whispery's git history.
tests/parity/fixtures/
